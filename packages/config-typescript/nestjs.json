{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./base.json",
  "compilerOptions": {
    "module": "node16",
    "moduleResolution": "node16",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "lib": ["ES2022"],
    "outDir": "dist",
    "sourceMap": true,
    "declaration": true,
    "removeComments": true,
    "incremental": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  }
}
