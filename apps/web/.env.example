# Base URL of the API (defaults to http://localhost:4000 when unset).
VITE_API_URL=http://localhost:4000

# PostHog (client-side analytics + error tracking). Leave VITE_POSTHOG_KEY empty
# to disable capture entirely. Use your project's "Project API Key" (phc_...).
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
