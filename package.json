{
  "name": "temply",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "turbo format",
    "test": "turbo test",
    "check-types": "turbo check-types",
    "generate": "turbo run generate",
    "db:generate": "pnpm --filter @temply/api db:generate",
    "db:migrate": "pnpm --filter @temply/api db:migrate",
    "db:studio": "pnpm --filter @temply/api db:studio"
  },
  "devDependencies": {
    "lint-staged": "^16.0.0",
    "prettier": "^3.8.1",
    "turbo": "^2.5.4",
    "typescript": "^6.0.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": ["eslint --fix", "prettier --write"],
    "*.{json,md,yaml,yml}": ["prettier --write"]
  },
  "packageManager": "pnpm@10.11.0",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "lightningcss", "@nestjs/core"]
  }
}
