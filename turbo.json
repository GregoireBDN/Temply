{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["generate", "^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".output/**", "dist/**"]
    },
    "generate": {
      "dependsOn": ["^generate"],
      "inputs": ["src/**/*.ts", "openapi.json", "openapi-ts.config.ts"],
      "outputs": ["openapi.json", "src/api/**"]
    },
    "@temply/web#generate": {
      "dependsOn": ["@temply/api#generate"],
      "inputs": ["openapi.json", "openapi-ts.config.ts"],
      "outputs": ["src/api/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["generate", "^check-types"]
    },
    "format": {
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"]
    }
  }
}
